# Copy to .env and edit before `docker compose up`.

# --- Database ---
# The password is interpolated into DATABASE_URL, so it must be URL-safe:
# use only letters and digits. `openssl rand -base64 32` emits `/` and `+`,
# which corrupt the URL — use `openssl rand -hex 24` instead.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=jamora_medusa

# --- Medusa secrets (generate strong random values!) ---
# e.g.  openssl rand -hex 32   (avoid `#` — it starts a comment in this file)
JWT_SECRET=change_me_jwt_secret
COOKIE_SECRET=change_me_cookie_secret

# --- Admin (CMS) login, created automatically on first boot ---
MEDUSA_ADMIN_EMAIL=admin@jamora.eu
MEDUSA_ADMIN_PASSWORD=Jamora2026!

# --- CORS: set to the URLs you actually browse from ---
# Storefront origin(s) allowed to call the store API:
STORE_CORS=http://localhost:3000
# The origin you open the admin dashboard on (e.g. http://YOUR_SERVER_IP:9000):
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000

# --- Storefront → Medusa publishable key ---
# Leave blank for the first `up`. After the backend boots, run:
#   docker compose logs medusa | grep PUBLISHABLE_KEY
# then paste the pk_... here and run: docker compose up -d storefront
MEDUSA_PUBLISHABLE_KEY=

# --- Host ports (optional) ---
MEDUSA_PORT=9000
STOREFRONT_PORT=3000
