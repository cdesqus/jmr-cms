{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "orderNumber": { "type": "string" },
    "trackingNumber": { "type": "string" },
    "carrier": { "type": "string" },
    "customerName": { "type": "string" },
    "email": { "type": "email", "required": true },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "paid", "processing", "shipped", "fulfilled", "failed", "refunded"],
      "default": "pending",
      "required": true
    },
    "currency": { "type": "string", "default": "eur", "required": true },
    "subtotalCents": { "type": "integer", "min": 0 },
    "shippingCents": { "type": "integer", "min": 0 },
    "discountCents": { "type": "integer", "min": 0 },
    "promotionCode": { "type": "string" },
    "totalCents": { "type": "integer", "required": true, "min": 0 },
    "estimatedProfitCents": { "type": "integer", "min": 0 },
    "stripeSessionId": { "type": "string" },
    "invoiceNumber": { "type": "string" },
    "items": { "type": "json" },
    "statusHistory": { "type": "json" },
    "reservationToken": { "type": "string" },
    "batchAllocations": { "type": "json" },
    "fulfilmentChecklist": { "type": "json" },
    "packedBy": { "type": "string" },
    "packedAt": { "type": "datetime" },
    "itemsSummary": { "type": "text" },
    "shippingAddressText": { "type": "text" },
    "trackingPreviewUrl": { "type": "string" },
    "deliveryLabelUrl": { "type": "string" },
    "estimatedDelivery": { "type": "datetime" }
  }
}
