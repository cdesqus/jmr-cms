{
  "kind": "collectionType",
  "collectionName": "notification_logs",
  "info": { "singularName": "notification-log", "pluralName": "notification-logs", "displayName": "Notification Log" },
  "options": { "draftAndPublish": false },
  "attributes": {
    "channel": { "type": "enumeration", "enum": ["email"], "default": "email", "required": true },
    "recipient": { "type": "string", "required": true },
    "template": { "type": "string", "required": true },
    "subject": { "type": "string", "required": true },
    "status": { "type": "enumeration", "enum": ["simulated", "sent", "failed"], "default": "simulated", "required": true },
    "orderNumber": { "type": "string" },
    "payload": { "type": "json" }
  }
}
